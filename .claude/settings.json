{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/go-fmt-autofix.sh\"",
            "statusMessage": "gofmt -s -w"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/commit-msg-check.sh\"",
            "if": "Bash(git commit *)",
            "timeout": 15,
            "statusMessage": "Checking commit message format"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/go-lint-check.sh\"",
            "if": "Bash(git commit *)",
            "timeout": 120,
            "statusMessage": "Running golangci-lint"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/go-build-check.sh\"",
            "if": "Bash(git commit *)",
            "timeout": 120,
            "statusMessage": "Running go build"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/go-prepush-check.sh\"",
            "if": "Bash(git push *)",
            "timeout": 180,
            "statusMessage": "Running go vet + go test"
          }
        ]
      }
    ]
  }
}
